# Source PDFs under pdfs/ ARE committed — via git-LFS (project Decision 2).
# See .gitattributes. So do NOT blanket-ignore *.pdf. Ignore only stray PDFs
# that land outside the tracked pdfs/ tree.
*.pdf
!pdfs/
!pdfs/**
# The tiny offline parse-pipeline test fixtures ARE committed (regenerate with
# tests/fixtures/generate_fixtures.py) — the suite needs them.
!tests/fixtures/*.pdf

# Legacy local raw-harvest staging (pre-Decision-2 layout), if ever created.
data/raw/

# Regenerated harvest outputs — produced fresh by each (dry-)run, not source of truth.
# The committed dataset (when we publish one) will be a deliberate snapshot, not these.
index/
manifest.csv
gaps.md

# Regenerated parse outputs — the publishable corpus is rebuilt from the PDFs +
# index by scripts/run_parse.py; the committed dataset (when published) will be a
# deliberate snapshot, not this working tree. (index/textlayer_report.json is
# already covered by the index/ rule above.)
corpus/

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Node (if an MCP server is added later)
node_modules/
dist/

# OS / editor
.DS_Store
.idea/
.vscode/
*.log
